#!/bin/python
import shlex
import sys
import fnmatch
import socket
import tomllib
import os
import ipaddress

config_path = "/etc/dccd.toml"

try:
    with open(config_path, "rb") as f:
        config = tomllib.load(f)
except FileNotFoundError:
    with open(config_path, "w") as f:
        f.write("""[whitelist]
# a list of name@ip saying which users from which ips can send
# you files
# this example accepts anyone from localhost
clients = ["*@127.0.0.0/8"]""")

    with open(config_path, "rb") as f:
        config = tomllib.load(f)

netconfig = config.get("network", {
    "blocksize": 5
})

filesystem = config.get("filesystem", {})

if downloads := filesystem.get("downloads"):
    download_dir = downloads
elif xdg_downloads := os.getenv("XDG_DOWNLOAD_HOME"):
    download_dir = xdg_downloads
elif home := os.getenv("HOME"):
    download_dir = home + "/Downloads"
elif user := os.getenv("USER"):
    download_dir = "/home/" + user + "/Downloads"
else:
    print("No downloads dir")
    exit(1)

chownas = filesystem.get("chown")

if not os.path.exists(download_dir):
    os.mkdir(download_dir)

if chownas:
    os.chown(download_dir, *chownas)


def send(conn: socket.socket, data: bytes, reprval = None):
    conn.sendall(data)
    text = f"> {data}"
    if reprval:
        text += f" ({reprval})"
    print(text, file=sys.stderr)

def handle_file_send_request(conn: socket.socket, addr: str, req: bytes):
    _, user, fsize, *fname = req.split(b" ")
    fname = " ".join([s.decode("utf-8") for s in fname]).encode("utf-8")
    if fname[0] == '"':
        fname = fname[1:-1]
    fsize = int(fsize.decode('utf-8'))
    fname = fname.decode("utf-8")
    user = user.decode('utf-8')
    print(f"< {req.decode('utf-8')}", file=sys.stderr)
    send(conn, b"121 euro@barney.local 0")
    blocksize = 1024 * 5
    recved = 0
    fpath = f'{download_dir}/DCC-FROM-{user}/{fname}'
    if not os.path.exists(fpath):
        os.mkdir(os.path.dirname(fpath))
        if chownas:
            os.chown(os.path.dirname(fpath), *chownas)
    with open(fpath, "wb") as f:
        try:
            hooks = config.get("hooks", {})
            if cmd := hooks.get("onreceive", ""):
                os.system(cmd.format(user=shlex.quote(user), fname=shlex.quote(fname), fsize=shlex.quote(str(fsize))))
        except Exception:
            pass
        while recved < fsize:
            req = conn.recv(blocksize)
            recved += len(req)
            f.write(req)
            send(conn, recved.to_bytes(4, byteorder="big"), recved)
    if chownas:
        os.chown(fpath, *chownas)

# def handle_chat_request(conn: socket.socket, req: bytes):
#     print(f"< {req.decode('utf-8')}", file=sys.stderr)
#     send(conn, b"100 anon")

def is_name_and_ip_whitelisted(name: str, ip: str):
    for item in config["whitelist"].get("clients", []):
        curname, *curip = item.split("@")
        rest = curip[:-1]
        curip = curip[-1]
        whitelistedip = ipaddress.ip_address(ip)
        network = ipaddress.ip_network(curip)
        if len(rest):
            curname += "@" + "@".join(rest)
        matches = len(fnmatch.filter([name], curname)) > 0
        if matches and whitelistedip in network:
            return True
    return False

with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
    s.bind(("0.0.0.0", 59))
    while True:
        s.listen(1)
        conn, addr = s.accept()
        with conn:
            req = conn.recv(1024)
            req_type, name, *rest = req.split(b" ")
            print(f"{name.decode('utf-8')}@{addr[0]} connected")
            if not is_name_and_ip_whitelisted(name.decode("utf-8"), addr[0]):
                print("not whitelisted")
            elif req_type == b"120":
                handle_file_send_request(conn, addr[0], req)
            elif req_type == b"100":
                handle_chat_request(conn, req)
